<section class="vossa-section bg-bone" style="padding-top: 120px;text-align:center;">
  <div class="vossa-section-inner" style="max-width:480px;">
    <p class="vossa-eyebrow">Account</p>
    <h1 style="margin-bottom:32px;">Create account.</h1>

    {% form 'create_customer' %}
      {{ form.errors | default_errors }}
      <div style="margin-bottom:14px;"><input type="text" name="customer[first_name]" placeholder="First name" required style="padding:14px 22px;border-radius:999px;border:1px solid var(--line);background:var(--mist);font-size:14px;font-family:inherit;width:100%;"></div>
      <div style="margin-bottom:14px;"><input type="text" name="customer[last_name]" placeholder="Last name" required style="padding:14px 22px;border-radius:999px;border:1px solid var(--line);background:var(--mist);font-size:14px;font-family:inherit;width:100%;"></div>
      <div style="margin-bottom:14px;"><input type="email" name="customer[email]" placeholder="Email" required style="padding:14px 22px;border-radius:999px;border:1px solid var(--line);background:var(--mist);font-size:14px;font-family:inherit;width:100%;"></div>
      <div style="margin-bottom:18px;"><input type="password" name="customer[password]" placeholder="Password" required style="padding:14px 22px;border-radius:999px;border:1px solid var(--line);background:var(--mist);font-size:14px;font-family:inherit;width:100%;"></div>
      <button type="submit" class="vossa-cta" style="font-family:var(--sans);width:100%;justify-content:center;">Create Account <span class="arrow">→</span></button>
      <p style="margin-top:18px;font-size:13px;color:var(--muted);">Already have one? <a href="/account/login" style="color:var(--sage);">Sign in</a></p>
    {% endform %}
  </div>
</section>
