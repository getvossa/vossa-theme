<section class="vossa-section bg-bone" style="padding-top: 140px;text-align:center;">
  <div class="vossa-section-inner" style="max-width:580px;">
    <p class="vossa-eyebrow">Vossa</p>
    <h1 style="margin-bottom:24px;">Opening soon.</h1>
    <p class="vossa-sub">The magnetic nasal dilator. Built for sleep, sport, and recovery.</p>

    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <input type="password" name="password" placeholder="Enter password" style="padding:14px 22px;border-radius:999px;border:1px solid var(--line);background:var(--mist);font-size:14px;font-family:inherit;width:100%;max-width:300px;margin-bottom:16px;">
      <br>
      <button type="submit" class="vossa-cta" style="font-family:var(--sans);">Enter <span class="arrow">→</span></button>
    {% endform %}
  </div>
</section>
