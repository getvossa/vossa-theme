<section class="vossa-section bg-bone" style="padding-top: 120px;">
  <div class="vossa-section-inner" style="max-width:780px;">
    <p class="vossa-eyebrow">{{ article.published_at | date: '%B %d, %Y' }}</p>
    <h1 style="margin-bottom:32px;">{{ article.title }}</h1>
    <div style="font-size:17px;line-height:1.7;color:var(--ink);">{{ article.content }}</div>
  </div>
</section>
