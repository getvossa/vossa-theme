<section class="vossa-section bg-bone" style="padding-top: 120px;">
  <div class="vossa-section-inner">
    <p class="vossa-eyebrow center">Search</p>
    <h1 class="center" style="margin-bottom:32px;">{% if search.performed %}Results for "{{ search.terms }}"{% else %}Search{% endif %}</h1>

    <form action="/search" method="get" role="search" class="center" style="margin-bottom:48px;">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search the store" style="padding:14px 22px;border-radius:999px;border:1px solid var(--line);background:var(--mist);font-size:14px;font-family:inherit;width:100%;max-width:400px;">
    </form>

    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p class="center" style="color:var(--muted);">No results for "{{ search.terms }}".</p>
      {% else %}
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;">
          {% for item in search.results %}
            <a href="{{ item.url }}" style="text-decoration:none;color:inherit;background:var(--mist);border:1px solid var(--line);border-radius:24px;padding:24px;display:block;">
              <p style="font-weight:600;color:var(--ink);">{{ item.title }}</p>
            </a>
          {% endfor %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</section>
