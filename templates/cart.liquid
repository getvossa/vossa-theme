<section class="vossa-section bg-bone" style="padding-top: 120px;">
  <div class="vossa-section-inner" style="max-width:820px;">
    <p class="vossa-eyebrow center">Your Cart</p>
    <h1 class="center" style="margin-bottom:48px;">{% if cart.item_count > 0 %}Almost there.{% else %}Your cart is empty.{% endif %}</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" novalidate>
        {% for item in cart.items %}
          <div style="display:grid;grid-template-columns:80px 1fr auto;gap:20px;align-items:center;padding:20px 0;border-bottom:1px solid var(--line);">
            <div style="width:80px;height:80px;border-radius:12px;overflow:hidden;background:var(--mist);">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" style="width:100%;height:100%;object-fit:cover;">
              {% endif %}
            </div>
            <div>
              <p style="font-weight:600;color:var(--ink);font-size:15px;margin-bottom:4px;"><a href="{{ item.url }}" style="color:inherit;text-decoration:none;">{{ item.product.title }}</a></p>
              <p style="font-size:13px;color:var(--muted);">{{ item.variant.title }}</p>
              <p style="font-size:14px;color:var(--sage);font-weight:500;margin-top:6px;">{{ item.final_price | money }}</p>
            </div>
            <div>
              <input type="number" name="updates[]" value="{{ item.quantity }}" min="0" style="width:60px;padding:8px;border-radius:8px;border:1px solid var(--line);text-align:center;font-family:inherit;">
            </div>
          </div>
        {% endfor %}

        <div style="margin-top:32px;text-align:right;">
          <p style="font-size:16px;color:var(--muted);margin-bottom:6px;">Subtotal</p>
          <p style="font-family:var(--display);font-size:36px;color:var(--ink);margin-bottom:24px;">{{ cart.total_price | money }}</p>
          <button type="submit" name="checkout" class="vossa-cta" style="font-family:var(--sans);">
            Check Out
            <span class="arrow">→</span>
          </button>
        </div>
      </form>
    {% else %}
      <p class="center" style="color:var(--muted);margin-bottom:32px;">Looks like you haven't added anything yet.</p>
      <p class="center">
        <a href="/collections/all" class="vossa-cta" style="font-family:var(--sans);">Continue Shopping <span class="arrow">→</span></a>
      </p>
    {% endif %}
  </div>
</section>
