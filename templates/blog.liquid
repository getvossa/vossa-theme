<section class="vossa-section bg-bone" style="padding-top: 120px;">
  <div class="vossa-section-inner">
    <p class="vossa-eyebrow center">Blog</p>
    <h1 class="center" style="margin-bottom:48px;">{{ blog.title }}</h1>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;">
      {% for article in blog.articles %}
        <a href="{{ article.url }}" style="text-decoration:none;color:inherit;background:var(--mist);border:1px solid var(--line);border-radius:24px;overflow:hidden;display:block;">
          <div style="padding:28px;">
            <p style="font-size:11px;text-transform:uppercase;letter-spacing:0.14em;color:var(--sage);font-weight:600;margin-bottom:12px;">{{ article.published_at | date: '%B %d, %Y' }}</p>
            <h3 style="font-size:20px;line-height:1.3;margin-bottom:12px;">{{ article.title }}</h3>
            <p style="font-size:14px;line-height:1.6;color:var(--muted);">{{ article.excerpt_or_content | strip_html | truncatewords: 24 }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>
