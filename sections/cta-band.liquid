<section class="vossa-section cta-band cta-band--compact">
  <svg class="breath-pattern" viewBox="0 0 1200 400" preserveAspectRatio="none">
    <g fill="none" stroke="currentColor" stroke-width="1">
      <path d="M 0 80 Q 300 20, 600 80 T 1200 80"/>
      <path d="M 0 140 Q 300 80, 600 140 T 1200 140"/>
      <path d="M 0 200 Q 300 140, 600 200 T 1200 200"/>
    </g>
  </svg>
  <div class="vossa-section-inner">
    <p class="vossa-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    {%- assign band_url = '/products/vossa-breathing-starter-kit' -%}
    {%- if section.settings.featured_product != blank -%}
      {%- assign band_url = section.settings.featured_product.url -%}
    {%- endif -%}
    <a class="vossa-cta vossa-cta--glass" href="{{ band_url }}">{{ section.settings.cta_text }} <span class="arrow">→</span></a>
    <p class="vossa-band-line">{{ section.settings.sub_line }}</p>
  </div>
</section>

{% schema %}
{
  "name": "CTA band",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Try Vossa Tonight"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Better sleep is one breath away."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "Shop the 90-Pack"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product (CTA links here)"
    },
    {
      "type": "text",
      "id": "sub_line",
      "label": "Sub-line",
      "default": "7-day trial \u00b7 Free shipping over $69 \u00b7 Designed in Canada"
    }
  ]
}
{% endschema %}
