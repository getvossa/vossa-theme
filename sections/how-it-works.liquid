<section class="vossa-section how" id="how">
  <svg class="breath-pattern" viewBox="0 0 1200 200" preserveAspectRatio="none">
    <g fill="none" stroke="currentColor" stroke-width="1">
      <path d="M 0 60 Q 200 10, 400 60 T 800 60 T 1200 60"/>
      <path d="M 0 100 Q 200 50, 400 100 T 800 100 T 1200 100"/>
      <path d="M 0 140 Q 200 90, 400 140 T 800 140 T 1200 140"/>
    </g>
  </svg>
  <div class="vossa-section-inner center">
    <p class="vossa-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="vossa-sub">{{ section.settings.sub }}</p>

    <div class="vossa-steps">
      <div class="vossa-step glass-card">
        <div class="vossa-step-bubble"><span>01</span></div>
        <h3>Choose your fit</h3>
        <p>Pick from 4 reusable magnetic bands (S, M, L, XL) until you find the size that hugs your nose perfectly. Keep that band — refill only the tabs.</p>
      </div>
      <div class="vossa-step glass-card">
        <div class="vossa-step-bubble"><span>02</span></div>
        <h3>Apply the tab</h3>
        <p>Stick one adhesive tab on clean, dry skin at the sides of your nose. Press for 10–15 seconds. The magnetic band snaps in instantly — no fumbling, no bridge pressure.</p>
      </div>
      <div class="vossa-step glass-card">
        <div class="vossa-step-bubble"><span>03</span></div>
        <h3>Breathe better</h3>
        <p>Your nasal valve opens within seconds. Sleep, train, recover — Vossa stays sealed through sweat, side-sleeping, and high-intensity movement.</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three steps. Better breath."
    },
    {
      "type": "textarea",
      "id": "sub",
      "label": "Sub-headline",
      "default": "No surgery, no pills, no awkward straps. A reusable magnetic band, a single tab, and a 60-second application."
    }
  ]
}
{% endschema %}
