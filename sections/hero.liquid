<section class="vossa-hero">
  <svg class="breath-pattern" viewBox="0 0 1200 200" preserveAspectRatio="none">
    <g fill="none" stroke="currentColor" stroke-width="1.2">
      <path d="M 0 60 Q 150 20, 300 60 T 600 60 T 900 60 T 1200 60"/>
      <path d="M 0 100 Q 150 60, 300 100 T 600 100 T 900 100 T 1200 100"/>
      <path d="M 0 140 Q 150 100, 300 140 T 600 140 T 900 140 T 1200 140"/>
    </g>
  </svg>

  {%- if section.settings.show_announcement -%}
    <div class="vossa-announce">
      <div class="glass">
        {{ section.settings.announcement_text }} <span class="dot">·</span> {{ section.settings.announcement_text_2 }} <span class="dot">·</span> {{ section.settings.announcement_text_3 }}
      </div>
    </div>
  {%- endif -%}

  <div class="vossa-hero-grid">
    <div class="vossa-hero-content">
      <p class="vossa-eyebrow">{{ section.settings.eyebrow }}</p>
      <h1>{{ section.settings.headline }}</h1>
      <p class="vossa-hero-sub">{{ section.settings.sub }}</p>
      <p class="vossa-hero-price">{{ section.settings.price_line }}</p>

      <div class="vossa-cta-row">
        {%- assign cta_url = '/products/vossa-breathing-starter-kit' -%}
        {%- if section.settings.featured_product != blank -%}
          {%- assign cta_url = section.settings.featured_product.url -%}
        {%- endif -%}
        <a class="vossa-cta vossa-cta--glass" href="{{ cta_url }}">
          {{ section.settings.cta_text }} <span class="arrow">→</span>
        </a>
        <a class="vossa-link" href="#how">How it works</a>
      </div>

      {%- if section.settings.show_rating_chip -%}
        <a class="vossa-rating-chip glass" href="#reviews" aria-label="Customer rating">
          <span class="vossa-rating-chip-stars" aria-hidden="true">
            <svg viewBox="0 0 20 20"><path d="M10 1l2.6 5.6 6.4.7-4.8 4.4 1.3 6.3L10 14.8 4.5 18l1.3-6.3L1 7.3l6.4-.7z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1l2.6 5.6 6.4.7-4.8 4.4 1.3 6.3L10 14.8 4.5 18l1.3-6.3L1 7.3l6.4-.7z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1l2.6 5.6 6.4.7-4.8 4.4 1.3 6.3L10 14.8 4.5 18l1.3-6.3L1 7.3l6.4-.7z"/></svg>
            <svg viewBox="0 0 20 20"><path d="M10 1l2.6 5.6 6.4.7-4.8 4.4 1.3 6.3L10 14.8 4.5 18l1.3-6.3L1 7.3l6.4-.7z"/></svg>
            <svg viewBox="0 0 20 20" class="vossa-star-half"><defs><linearGradient id="halfgrad"><stop offset="50%" stop-color="currentColor"/><stop offset="50%" stop-color="rgba(0,0,0,0.12)"/></linearGradient></defs><path fill="url(#halfgrad)" d="M10 1l2.6 5.6 6.4.7-4.8 4.4 1.3 6.3L10 14.8 4.5 18l1.3-6.3L1 7.3l6.4-.7z"/></svg>
          </span>
          <span class="vossa-rating-chip-score">{{ section.settings.rating_chip_score }}</span>
          <span class="vossa-rating-chip-sep" aria-hidden="true"></span>
          <span class="vossa-rating-chip-label">{{ section.settings.rating_chip_label }}</span>
        </a>
      {%- endif -%}
    </div>

    <div class="vossa-hero-media">
      <div class="vossa-media-frame">
        {%- if section.settings.hero_image != blank -%}
          {%- assign hero_img = section.settings.hero_image -%}
          <img
            class="vossa-hero-img"
            src="{{ hero_img | image_url: width: 1400 }}"
            srcset="{{ hero_img | image_url: width: 700 }} 700w, {{ hero_img | image_url: width: 1400 }} 1400w, {{ hero_img | image_url: width: 2000 }} 2000w"
            sizes="(max-width: 900px) 100vw, 50vw"
            alt="{{ hero_img.alt | default: 'Vossa magnetic nasal dilator' | escape }}"
            loading="eager"
            fetchpriority="high"
            width="{{ hero_img.width }}"
            height="{{ hero_img.height }}">
        {%- else -%}
          <div class="vossa-product-mock">Upload hero image<br>in customizer<small>4:5 ratio recommended</small></div>
        {%- endif -%}

        {%- if section.settings.show_feature_card -%}
          {%- if section.settings.featured_product != blank -%}
            <a href="{{ section.settings.featured_product.url }}" class="vossa-feature-card vossa-feature-card--link glass" aria-label="View product details">
              <div class="vossa-feature-card-text">
                <p class="vossa-feat-label">{{ section.settings.feature_label }}</p>
                <p class="vossa-feat-value">{{ section.settings.feature_value }}</p>
              </div>
              <span class="vossa-feature-card-arrow" aria-hidden="true">→</span>
            </a>
          {%- else -%}
            <div class="vossa-feature-card glass">
              <p class="vossa-feat-label">{{ section.settings.feature_label }}</p>
              <p class="vossa-feat-value">{{ section.settings.feature_value }}</p>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "header",
      "content": "Announcement bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": false
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement 1",
      "default": "Free Shipping on Orders $69+"
    },
    {
      "type": "text",
      "id": "announcement_text_2",
      "label": "Announcement 2",
      "default": "7-Day Trial"
    },
    {
      "type": "text",
      "id": "announcement_text_3",
      "label": "Announcement 3",
      "default": "Designed in Canada"
    },
    {
      "type": "header",
      "content": "Hero content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Vossa\u2122 \u00b7 The Magnetic Nasal Dilator"
    },
    {
      "type": "richtext",
      "id": "headline",
      "label": "Headline",
      "default": "<p>Breathe deeper.<br>Sleep harder.<br>Train sharper.</p>"
    },
    {
      "type": "textarea",
      "id": "sub",
      "label": "Sub-headline",
      "default": "Engineered to open the nasal valve \u2014 the narrowest part of your airway \u2014 so you can stop mouth breathing for good. Reusable magnetic band, replaceable tabs, designed for nightly use."
    },
    {
      "type": "text",
      "id": "price_line",
      "label": "Price line",
      "default": "90 tabs \u00b7 45 nights of nightly use \u00b7 7-day trial"
    },
    {
      "type": "header",
      "content": "CTA"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop the 90-Pack"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured product (CTA + feature-card link)"
    },
    {
      "type": "header",
      "content": "Rating chip (under CTA button)"
    },
    {
      "type": "checkbox",
      "id": "show_rating_chip",
      "label": "Show rating chip under the CTA button",
      "default": true,
      "info": "Per §9 guardrail: keep the label text factual until real Vossa reviews exist."
    },
    {
      "type": "text",
      "id": "rating_chip_score",
      "label": "Score (shown big)",
      "default": "4.5"
    },
    {
      "type": "text",
      "id": "rating_chip_label",
      "label": "Label text (right of score)",
      "default": "100,000+ Happy customers",
      "info": "Editable. Default is the defensible option. You are responsible for whatever you type here."
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (4:5 ratio recommended)"
    },
    {
      "type": "checkbox",
      "id": "show_feature_card",
      "label": "Show floating feature card (also links to product)",
      "default": true
    },
    {
      "type": "text",
      "id": "feature_label",
      "label": "Feature card label",
      "default": "Inside the kit"
    },
    {
      "type": "text",
      "id": "feature_value",
      "label": "Feature card value",
      "default": "90 magnetic tabs \u00b7 4 reusable bands"
    }
  ]
}
{% endschema %}
