<footer class="vossa-footer">
  <div class="vossa-footer-inner">
    <div class="vossa-newsletter">
      <div class="vossa-newsletter-text">
        <h3>{{ section.settings.newsletter_heading }}</h3>
        <p>{{ section.settings.newsletter_sub }}</p>
      </div>
      <div class="vossa-newsletter-form-wrap">
        {%- form 'customer', class: 'vossa-newsletter-form-glass' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="vossa-pill-input glass">
            <svg class="vossa-pill-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <input type="email" name="contact[email]" placeholder="your@email.com" required class="vossa-pill-email">
            <button type="submit" class="vossa-pill-btn">Subscribe</button>
          </div>
        {%- endform -%}
      </div>
    </div>

    <div class="vossa-footer-top">
      <div>
        <div class="vossa-footer-brand">
          <span class="vossa-logomark" aria-hidden="true"></span>
          <span class="vossa-footer-name">Vossa</span>
        </div>
        <p class="vossa-footer-tag">{{ section.settings.footer_tagline }}</p>
        <div class="vossa-socials">
          {%- if section.settings.instagram_url != blank -%}<a class="vossa-soc" href="{{ section.settings.instagram_url }}" aria-label="Instagram"><svg viewBox="0 0 24 24"><path d="M12 2.16c3.2 0 3.58 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.43.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.43.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.43-.36-1.06-.41-2.23C2.18 15.58 2.16 15.2 2.16 12s.01-3.67.07-4.95c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.43-.16 1.06-.36 2.23-.41C8.42 2.18 8.8 2.16 12 2.16M12 0C8.74 0 8.33.01 7.05.07 5.77.13 4.9.33 4.14.63a5.86 5.86 0 0 0-2.13 1.38A5.86 5.86 0 0 0 .63 4.14C.33 4.9.13 5.77.07 7.05.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.15.56 2.91a5.86 5.86 0 0 0 1.38 2.13 5.86 5.86 0 0 0 2.13 1.38c.76.3 1.63.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.28-.06 2.15-.26 2.91-.56a5.86 5.86 0 0 0 2.13-1.38 5.86 5.86 0 0 0 1.38-2.13c.3-.76.5-1.63.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.15-.56-2.91a5.86 5.86 0 0 0-1.38-2.13A5.86 5.86 0 0 0 19.86.63c-.76-.3-1.63-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zm0 10.16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.4-11.85a1.44 1.44 0 1 0 0 2.88 1.44 1.44 0 0 0 0-2.88z"/></svg></a>{%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}<a class="vossa-soc" href="{{ section.settings.tiktok_url }}" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.78 20.1a6.34 6.34 0 0 0 10.86-4.43V8.69a8.16 8.16 0 0 0 4.77 1.52V6.78a4.85 4.85 0 0 1-1.82-.09z"/></svg></a>{%- endif -%}
          {%- if section.settings.youtube_url != blank -%}<a class="vossa-soc" href="{{ section.settings.youtube_url }}" aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M23.5 6.2a3 3 0 0 0-2.12-2.13C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.38.57A3 3 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3 3 0 0 0 2.12 2.13C4.5 20.5 12 20.5 12 20.5s7.5 0 9.38-.57a3 3 0 0 0 2.12-2.13A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8zM9.75 15.57V8.43L15.82 12z"/></svg></a>{%- endif -%}
        </div>
      </div>
      <div class="vossa-footer-col">
        <h4>Shop</h4>
        <a href="/products/vossa-breathing-starter-kit">Breathing Starter Kit</a>
        <a href="/products/vossa-refill-tabs-30-pack">Refill Tabs — 30 Pack</a>
        <a href="/products/vossa-mouth-tape">Mouth Tape</a>
      </div>
      <div class="vossa-footer-col">
        <h4>Support</h4>
        <a href="/pages/contact">Contact</a>
        <a href="/pages/track-my-order">Track my order</a>
        <a href="/#faq">FAQ</a>
      </div>
      <div class="vossa-footer-col">
        <h4>Legal</h4>
        <a href="/policies/refund-policy">Refund Policy</a>
        <a href="/policies/shipping-policy">Shipping Policy</a>
        <a href="/policies/privacy-policy">Privacy Policy</a>
        <a href="/policies/terms-of-service">Terms of Service</a>
        <a href="/pages/data-sharing-opt-out">Your Privacy Choices</a>
      </div>
    </div>

    <div class="vossa-footer-bot">
      <span>{{ section.settings.copyright }}</span>
      <span><a href="/policies/privacy-policy">Privacy</a> · <a href="/policies/terms-of-service">Terms</a></span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Join the breathing revolution."
    },
    {
      "type": "text",
      "id": "newsletter_sub",
      "label": "Newsletter sub",
      "default": "Sleep science, exclusive drops, and early access — straight to your inbox."
    },
    {
      "type": "header",
      "content": "Footer brand"
    },
    {
      "type": "text",
      "id": "footer_tagline",
      "label": "Footer tagline",
      "default": "The magnetic nasal dilator. Built for sleep, sport, and recovery. Designed in Canada."
    },
    {
      "type": "header",
      "content": "Shop links"
    },
    {
      "type": "product",
      "id": "kit_link",
      "label": "90-Pack Kit product"
    },
    {
      "type": "product",
      "id": "refill_link",
      "label": "Refill Tabs product"
    },
    {
      "type": "header",
      "content": "Socials"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright line",
      "default": "\u00a9 2026 Vossa \u00b7 Designed in Canada"
    }
  ]
}
{% endschema %}
