<section class="vossa-section ugc" id="stories">
  <div class="vossa-section-inner">
    <p class="vossa-eyebrow">{{ section.settings.eyebrow }}</p>
    <h2>{{ section.settings.heading }}</h2>
    <p class="vossa-sub">{{ section.settings.sub }}</p>

    <div class="vossa-ugc-track-wrap">
      <div class="vossa-ugc-track">
        {%- for i in (1..5) -%}
          {%- assign url_key     = 'video_url_' | append: i -%}
          {%- assign cover_key   = 'video_cover_' | append: i -%}
          {%- assign caption_key = 'video_caption_' | append: i -%}
          {%- assign url_val     = section.settings[url_key] -%}
          {%- assign cover_val   = section.settings[cover_key] -%}
          {%- assign caption_val = section.settings[caption_key] -%}

          <div class="vossa-ugc-card">
            <div class="vossa-ugc-media">
              {%- if cover_val != blank -%}
                <img
                  class="vossa-ugc-cover"
                  src="{{ cover_val | image_url: width: 600 }}"
                  alt="{{ caption_val | default: 'Customer story' | escape }}"
                  loading="lazy"
                  width="{{ cover_val.width }}"
                  height="{{ cover_val.height }}">
              {%- else -%}
                <div class="vossa-ugc-media--empty">
                  <p>Upload thumbnail<br><small>video {{ i }}</small></p>
                </div>
              {%- endif -%}

              {%- if url_val != blank -%}
                <a class="vossa-ugc-play" href="{{ url_val }}" target="_blank" rel="noopener" aria-label="Play video {{ i }}">
                  <svg viewBox="0 0 24 24" width="40" height="40"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.55)"/><polygon points="10 8 16 12 10 16 10 8" fill="white"/></svg>
                </a>
              {%- endif -%}
            </div>

            {%- if caption_val != blank -%}
              <p class="vossa-ugc-caption">{{ caption_val }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Video Stories",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real People. Real Results." },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Hear it from them." },
    { "type": "textarea", "id": "sub", "label": "Sub", "default": "Vossa customers share their experience." },

    { "type": "header", "content": "Video 1" },
    { "type": "image_picker", "id": "video_cover_1", "label": "Thumbnail" },
    { "type": "text", "id": "video_url_1", "label": "Video URL (YouTube / Vimeo / Shopify Files)" },
    { "type": "text", "id": "video_caption_1", "label": "Caption" },

    { "type": "header", "content": "Video 2" },
    { "type": "image_picker", "id": "video_cover_2", "label": "Thumbnail" },
    { "type": "text", "id": "video_url_2", "label": "Video URL" },
    { "type": "text", "id": "video_caption_2", "label": "Caption" },

    { "type": "header", "content": "Video 3" },
    { "type": "image_picker", "id": "video_cover_3", "label": "Thumbnail" },
    { "type": "text", "id": "video_url_3", "label": "Video URL" },
    { "type": "text", "id": "video_caption_3", "label": "Caption" },

    { "type": "header", "content": "Video 4" },
    { "type": "image_picker", "id": "video_cover_4", "label": "Thumbnail" },
    { "type": "text", "id": "video_url_4", "label": "Video URL" },
    { "type": "text", "id": "video_caption_4", "label": "Caption" },

    { "type": "header", "content": "Video 5" },
    { "type": "image_picker", "id": "video_cover_5", "label": "Thumbnail" },
    { "type": "text", "id": "video_url_5", "label": "Video URL" },
    { "type": "text", "id": "video_caption_5", "label": "Caption" }
  ],
  "presets": [
    { "name": "Video Stories" }
  ]
}
{% endschema %}
