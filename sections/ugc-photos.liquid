<section class="vossa-section ugc-photos">
  <div class="vossa-section-inner">
    <p class="vossa-eyebrow center">{{ section.settings.eyebrow }}</p>
    <h2 class="center">{{ section.settings.heading }}</h2>
    <p class="vossa-sub">{{ section.settings.sub }}</p>

    <div class="vossa-ugc-photos-grid">
      {%- for i in (1..6) -%}
        {%- assign img_key     = 'photo_'   | append: i -%}
        {%- assign caption_key = 'caption_' | append: i -%}
        {%- assign name_key    = 'name_'    | append: i -%}
        {%- assign tag_key     = 'tag_'     | append: i -%}

        {%- assign img     = section.settings[img_key] -%}
        {%- assign caption = section.settings[caption_key] -%}
        {%- assign name    = section.settings[name_key] -%}
        {%- assign tag     = section.settings[tag_key] -%}

        {%- if img != blank or caption != blank or name != blank -%}
          <figure class="vossa-ugc-photo-card glass-card">
            <div class="vossa-ugc-photo-frame">
              {%- if img != blank -%}
                <img
                  class="vossa-ugc-photo-img"
                  src="{{ img | image_url: width: 800 }}"
                  srcset="{{ img | image_url: width: 400 }} 400w, {{ img | image_url: width: 800 }} 800w, {{ img | image_url: width: 1200 }} 1200w"
                  sizes="(max-width: 900px) 100vw, 33vw"
                  alt="{{ img.alt | default: name | default: 'Vossa customer photo' | escape }}"
                  loading="lazy"
                  width="{{ img.width }}"
                  height="{{ img.height }}">
              {%- else -%}
                <div class="vossa-ugc-photo-placeholder">
                  <svg viewBox="0 0 24 24" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                  <span>Upload photo {{ i }}</span>
                </div>
              {%- endif -%}
              {%- if tag != blank -%}
                <span class="vossa-ugc-photo-tag glass">{{ tag }}</span>
              {%- endif -%}
            </div>
            {%- if caption != blank or name != blank -%}
              <figcaption class="vossa-ugc-photo-body">
                {%- if caption != blank -%}
                  <p class="vossa-ugc-photo-caption">{{ caption }}</p>
                {%- endif -%}
                {%- if name != blank -%}
                  <p class="vossa-ugc-photo-name">— {{ name }}</p>
                {%- endif -%}
              </figcaption>
            {%- endif -%}
          </figure>
        {%- else -%}
          <figure class="vossa-ugc-photo-card vossa-ugc-photo-card--empty">
            <div class="vossa-ugc-photo-frame">
              <div class="vossa-ugc-photo-placeholder">
                <svg viewBox="0 0 24 24" width="32" height="32"><rect x="3" y="3" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="8.5" cy="8.5" r="1.5" fill="currentColor"/><path d="M21 15l-5-5L5 21" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
                <span>Slot {{ i }} — add in customizer</span>
              </div>
            </div>
          </figure>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "UGC Photos",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "REAL CUSTOMERS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quiet nights. Open noses."
    },
    {
      "type": "textarea",
      "id": "sub",
      "label": "Sub heading",
      "default": "Photos from the people sleeping in Vossa right now. No actors, no stock photos, no edits."
    },
    { "type": "header", "content": "Photo 1" },
    { "type": "image_picker", "id": "photo_1", "label": "Photo" },
    { "type": "text", "id": "tag_1", "label": "Corner tag (optional)", "info": "e.g. 'Night 3'" },
    { "type": "text", "id": "caption_1", "label": "Caption" },
    { "type": "text", "id": "name_1", "label": "Customer name / handle" },
    { "type": "header", "content": "Photo 2" },
    { "type": "image_picker", "id": "photo_2", "label": "Photo" },
    { "type": "text", "id": "tag_2", "label": "Corner tag (optional)" },
    { "type": "text", "id": "caption_2", "label": "Caption" },
    { "type": "text", "id": "name_2", "label": "Customer name / handle" },
    { "type": "header", "content": "Photo 3" },
    { "type": "image_picker", "id": "photo_3", "label": "Photo" },
    { "type": "text", "id": "tag_3", "label": "Corner tag (optional)" },
    { "type": "text", "id": "caption_3", "label": "Caption" },
    { "type": "text", "id": "name_3", "label": "Customer name / handle" },
    { "type": "header", "content": "Photo 4" },
    { "type": "image_picker", "id": "photo_4", "label": "Photo" },
    { "type": "text", "id": "tag_4", "label": "Corner tag (optional)" },
    { "type": "text", "id": "caption_4", "label": "Caption" },
    { "type": "text", "id": "name_4", "label": "Customer name / handle" },
    { "type": "header", "content": "Photo 5" },
    { "type": "image_picker", "id": "photo_5", "label": "Photo" },
    { "type": "text", "id": "tag_5", "label": "Corner tag (optional)" },
    { "type": "text", "id": "caption_5", "label": "Caption" },
    { "type": "text", "id": "name_5", "label": "Customer name / handle" },
    { "type": "header", "content": "Photo 6" },
    { "type": "image_picker", "id": "photo_6", "label": "Photo" },
    { "type": "text", "id": "tag_6", "label": "Corner tag (optional)" },
    { "type": "text", "id": "caption_6", "label": "Caption" },
    { "type": "text", "id": "name_6", "label": "Customer name / handle" }
  ],
  "presets": [
    { "name": "UGC Photos" }
  ]
}
{% endschema %}
