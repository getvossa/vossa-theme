<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="theme-color" content="#FBFAF5">
  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- endif -%}

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {{ 'vossa.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-{{ template.name | handle }}">

  <a class="skip-to-content-link visually-hidden" href="#MainContent">Skip to content</a>

  {% section 'header' %}

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <style>
    .skip-to-content-link {
      position: absolute;
      left: -9999px;
      z-index: 999;
      background: #3F7A5E;
      color: #FBFAF5;
      padding: 12px 16px;
      border-radius: 0 0 8px 0;
      text-decoration: none;
    }
    .skip-to-content-link:focus {
      left: 0; top: 0;
    }
    .visually-hidden {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }
  </style>

  <script>
    (function() {
      // Wait for DOM
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFadeIn);
      } else {
        initFadeIn();
      }

      function initFadeIn() {
        var targets = document.querySelectorAll('.vossa-section-inner, .vossa-brand-inner');

        // Reduced motion or no IO support → show everything
        if (!('IntersectionObserver' in window) ||
            window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          targets.forEach(function(el) { el.classList.add('is-visible'); });
          return;
        }

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, {
          rootMargin: '0px 0px -12% 0px',
          threshold: 0.08
        });

        targets.forEach(function(el) { observer.observe(el); });
      }
    })();
  </script>

</body>
</html>
